{
  "name": "smkn2-ai-assistant",
  "version": "1.0.0",
  "description": "AI Assistant SMKN 2 Mataram - WhatsApp Chatbot",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "train": "node train/ingest.js",
    "dev": "node src/server.js",
    "postinstall": "npx prisma generate --schema=prisma/schema.prisma && node -e \"const fs=require('fs');const d='src/generated/prisma';if(!fs.existsSync(d+'/client.js')){fs.readdirSync(d).filter(f=>f.endsWith('.ts')).forEach(f=>fs.copyFileSync(d+'/'+f,d+'/'+f.replace('.ts','.js')))}\"",
    "vercel-build": "npx prisma generate --schema=prisma/schema.prisma && node -e \"const fs=require('fs');const d='src/generated/prisma';fs.readdirSync(d).filter(f=>f.endsWith('.ts')).forEach(f=>fs.copyFileSync(d+'/'+f,d+'/'+f.replace('.ts','.js')))\""
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-fetch": "^2.7.0",
    "prisma": "^7.8.0"
  }
}
